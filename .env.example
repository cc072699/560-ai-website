# 管理员登录账号
ADMIN_USERNAME=admin

# 管理员密码（bcrypt 哈希值，用 openssl 或在线工具生成）
# 示例: node -e "require('bcryptjs').hash('your-password', 10).then(console.log)"
ADMIN_PASSWORD_HASH=\$2b\$10\$43Td1Fj1x8kHG9Npzl1oWOr0uS9LQjnqan/RDHHz/DW2MTNNsX/A6

# JWT 签名密钥（生产环境务必替换为强随机字符串）
# 生成: openssl rand -base64 32
NEXTAUTH_SECRET=XDzt3Cv64xgYXYGnT1VFD4p7vyblfz3GE6UROkURemQ=